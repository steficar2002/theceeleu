<!-- The trigger button is now handled by the header hamburger icon -->

<div id="floating-menu-modal" class="floating-menu__modal" aria-hidden="true" tabindex="-1">
  <button class="floating-menu__close" type="button" aria-label="Close menu">&times;</button>
  <nav class="floating-menu__nav" role="navigation" aria-label="Main menu">
    <ul class="floating-menu__list">
      {% for link in linklists.main-menu.links %}
        <li class="floating-menu__item">
          <a href="{{ link.url }}" class="floating-menu__link">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</div>

<style>
.floating-menu__trigger {
  background: none;
  border: none;
  font-size: 2rem;
  cursor: pointer;
  z-index: 10001;
  position: fixed;
  top: 30px;
  right: 30px;
  color: var(--color-foreground, #111);
}

.floating-menu__modal {
  display: none;
  position: fixed;
  left: 20px;
  right: 20px;
  max-width: calc(100% - 40px);
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  border: 1px solid rgba(0,0,0,0.1);
  border-bottom: 2px solid rgba(0,0,0,0.08);
  border-top: 1px solid rgba(0,0,0,0.12);
  padding: 32px 24px 24px 24px;
  z-index: 10000;
  top: 80px;
  transition: opacity 0.3s, transform 0.3s;
  opacity: 0;
  pointer-events: none;
}

.floating-menu__modal[aria-hidden="false"] {
  display: block;
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.floating-menu__close {
  background: none;
  border: none;
  font-size: 2rem;
  position: absolute;
  top: 18px;
  right: 18px;
  cursor: pointer;
  color: rgba(0, 0, 0, 0.7);
  transition: color 0.2s;
}

.floating-menu__close:hover {
  color: rgba(0, 0, 0, 1);
}

.floating-menu__nav {
  margin-top: 32px;
}

.floating-menu__list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.floating-menu__item {
  margin-bottom: 1.5rem;
}

.floating-menu__link {
  font-size: 1.5rem;
  color: rgba(0, 0, 0, 0.8);
  text-decoration: none;
  font-weight: 600;
  transition: color 0.2s;
}

.floating-menu__link:hover {
  color: rgba(0, 0, 0, 1);
}

@media screen and (width < 750px) {
  .floating-menu__trigger {
    top: auto;
    bottom: 30px;
    right: 30px;
  }
  .floating-menu__modal {
    top: auto;
    bottom: calc(var(--header-height, 60px) + 30px);
  }
}

.header__column--right {
  white-space: nowrap;
  flex-shrink: 0;
}

.header__column--right header-actions {
  display: flex;
  align-items: center;
  gap: var(--gap-sm);
  flex-wrap: nowrap;
}

.header-actions__action {
  min-width: 0;
  flex-shrink: 0;
}
</style>

<script>
(function() {
  var trigger = document.getElementById('floating-menu-trigger');
  var modal = document.getElementById('floating-menu-modal');
  var closeBtn = modal.querySelector('.floating-menu__close');

  function openMenu() {
    modal.setAttribute('aria-hidden', 'false');
    trigger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    modal.setAttribute('aria-hidden', 'true');
    trigger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  trigger.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });
})();
</script> 