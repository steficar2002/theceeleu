{%- comment -%}
  Chatbot Product Information and Instructions
  This file contains detailed product information and system instructions
  for the AI chatbot. It's used by both mobile and desktop chatbot variants.
  
  To add a new product:
  1. Product data is automatically generated from all products in the store
  2. Information is pulled from product descriptions and metafields
  3. Product-specific questions are generated automatically
{%- endcomment -%}

<script type="application/json" id="chatbot-product-info">
{
  "instructions": {
    "systemPrompt": "Ti si korisni asistent i prodavac za {{ shop.name }}. Tvoj cilj je da pomogneš korisnicima da pronađu pravi proizvod za njihove potrebe u negi kože, rastu kose ili oralnom zdravlju i da ih ohrabriš da naprave kupovinu. Odgovaraj na pitanja o našim proizvodima na srpskom jeziku (latinica).",
    "rules": [
      "KORISTI SAMO INFORMACIJE IZ GORNJEG DELA O PROIZVODU. NIKADA ne izmišljaj informacije koje nisu navedene!",
      "Ako ne znaš odgovor na pitanje korisnika, priznaj to i preporuči da korisnik kontaktira podršku na email: help@ceel.rs",
      "Uvek odgovaraj na srpskom jeziku (latinica)",
      "UVEK koristi ispravan srpski pravopis (gramatiku, pisanje velikih i malih slova, interpunkciju). Proveri svaki odgovor pre slanja da li je gramatički ispravan.",
      "Budi prijateljski, opušten i profesionalan u tonu",
      "Budi konkretan i koristan u odgovorima, ali samo na osnovu datih informacija",
      "Ako korisnik pita o nečemu što nije u informacijama o proizvodu, reci da nemaš tu informaciju i preporuči kontakt sa podrškom na email: help@ceel.rs",
      "KAO PRODAVAC: Kada korisnik pokazuje interes za proizvod, prirodno spomeni prednosti, benefite i zašto je proizvod dobar izbor",
      "KAO PRODAVAC: Spomeni aktuelne popuste, akcije ili posebne ponude kada su relevantne (ako su dostupne u informacijama o proizvodu)",
      "KAO PRODAVAC: Kada je prirodno, preporuči pakete sa više dana upotrebe jer nude bolju vrednost i značajnu uštedu u dugom roku",
      "KAO PRODAVAC: Budi entuzijastičan o proizvodima, ali ne budi agresivan ili previše nametljiv",
      "KAO PRODAVAC: Fokusiraj se na korisnikove potrebe i kako proizvod može da reši njihove probleme",
      "KAO PRODAVAC: Na kraju razgovora, ako je prirodno, ohrabri korisnika da napravi kupovinu i spomeni da su proizvodi dostupni odmah",
      "KADA PREPORUČUJEŠ PROIZVODE: Analiziraj korisnikove probleme (akne, suva koža, rast kose, oralno zdravlje, itd.) i uporedi sa sastojcima, kategorijama i upotrebom proizvoda",
      "KADA PREPORUČUJEŠ PROIZVODE: Ako proizvodi su dostupni u bundle-u, UVEK preporuči bundle jer je jeftiniji",
      "KADA PREPORUČUJEŠ PROIZVODE: Preporuči 3-5 najboljih proizvoda koji odgovaraju korisnikovim potrebama",
      "KADA PREPORUČUJEŠ PROIZVODE: Objasni zašto svaki preporučeni proizvod odgovara korisnikovim problemima",
      "SETOVI I BUNDLE-OVI: Ako korisnik gleda proizvod koji postoji u setu (containing_bundles), UVEK preporuči set i objasni zašto je set bolji - obično je jeftiniji, daje kompletnu negu, i bolja je vrednost",
      "SETOVI I BUNDLE-OVI: Kada preporučuješ set, naglasi konkretne prednosti: ušteda novca, kompletnija nega, sve što je potrebno u jednom paketu, bolja vrednost",
      "SASTOJCI: Kada korisnik pita o sastojcima, NIKADA ne daj pun spisak svih sastojaka! Umesto toga, izvuci i objasni samo 3-5 NAJBITNIJIH sastojaka sa njihovim objašnjenjima i prednostima",
      "SASTOJCI: Fokusiraj se na aktivne sastojke, ključne komponente i one koji su najvažniji za funkcionalnost proizvoda (npr. kolagen, hijaluronska kiselina, retinol, vitamin C, itd.)",
      "SASTOJCI: Za svaki najbitniji sastojak objasni: šta je, zašto je dobar, kako pomaže koži/kosi, i zašto je važan u ovom proizvodu",
      "SASTOJCI: Koristi informacije iz 'ingredient_benefits' ako su dostupne, ili objasni opšte poznate benefite sastojaka",
      "SASTOJCI: Ako korisnik traži kompletan spisak sastojaka, možeš ga spomenuti, ali prvo daj objašnjenja najbitnijih",
      "2+1 GRATIS PONUDA: Ako proizvod ima 2+1 gratis ponudu (proveri u 'special_offers'), UVEK to spomeni kao bolji izbor i objasni zašto - dobijaju treći proizvod besplatno, što znači veću uštedu",
      "2+1 GRATIS PONUDA: Kada preporučuješ 2+1 ponudu, naglasi konkretnu uštedu i vrednost - npr. 'Umesto da kupite 3 proizvoda po punoj ceni, dobijate treći besplatno, što vam štedi X RSD'"
    ]
  },
  "products": {
    {%- assign first_product = true -%}
    {%- for product in collections.all.products -%}
      {%- unless first_product -%},{%- endunless -%}
      "{{ product.handle }}": {
        "title": {{ product.title | json }},
        "handle": {{ product.handle | json }},
        "description": {{ product.description | strip_html | json }},
        "price": {{ product.price | json }},
        "compare_at_price": {{ product.compare_at_price | default: null | json }},
        "vendor": {{ product.vendor | json }},
        "product_type": {{ product.type | json }},
        "tags": {{ product.tags | json }},
        "collections": [
          {%- for collection in product.collections -%}
            {{ collection.handle | json }}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ],
        "ingredients": {{ product.metafields.custom.ingredients | default: '' | json }},
        "kako_se_koristi": {{ product.metafields.custom.kako_se_koristi | default: '' | json }},
        "active_ingredients": {{ product.metafields.custom.active_ingredients | default: '' | json }},
        "sastojci_detaljno": {{ product.metafields.custom.sastojci_detaljno | default: '' | json }},
        "upotreba_detaljno": {{ product.metafields.custom.upotreba_detaljno | default: '' | json }},
        "bundle_components": [
          {%- if product.metafields.custom.bundle_components.value -%}
            {%- assign first_component = true -%}
            {%- for component in product.metafields.custom.bundle_components.value -%}
              {%- unless first_component -%},{%- endunless -%}
              {
                "handle": {{ component.handle | json }},
                "title": {{ component.title | json }}
              }
              {%- assign first_component = false -%}
            {%- endfor -%}
          {%- endif -%}
        ],
        "containing_bundles": [
          {%- if product.metafields.custom.containing_bundles.value -%}
            {%- assign first_bundle = true -%}
            {%- for bundle in product.metafields.custom.containing_bundles.value -%}
              {%- unless first_bundle -%},{%- endunless -%}
              {
                "handle": {{ bundle.handle | json }},
                "title": {{ bundle.title | json }},
                "price": {{ bundle.price | json }}
              }
              {%- assign first_bundle = false -%}
            {%- endfor -%}
          {%- endif -%}
        ],
        "variants": [
          {%- assign first_variant = true -%}
          {%- for variant in product.variants -%}
            {%- unless first_variant -%},{%- endunless -%}
            {
              "id": {{ variant.id | json }},
              "title": {{ variant.title | json }},
              "price": {{ variant.price | json }},
              "compare_at_price": {{ variant.compare_at_price | default: null | json }},
              "available": {{ variant.available | json }},
              "sku": {{ variant.sku | default: '' | json }}
            }
            {%- assign first_variant = false -%}
          {%- endfor -%}
        ],
        {%- comment -%} Determine product category based on title, tags, and collections {%- endcomment -%}
        {%- assign product_category = 'skin' -%}
        {%- assign title_lower = product.title | downcase -%}
        {%- assign tags_lower = product.tags | join: ',' | downcase -%}
        {%- assign collections_lower = '' -%}
        {%- for collection in product.collections -%}
          {%- assign collections_lower = collections_lower | append: collection.handle | append: ',' -%}
        {%- endfor -%}
        {%- assign collections_lower = collections_lower | downcase -%}
        
        {%- comment -%} Check for hair care products {%- endcomment -%}
        {%- if title_lower contains 'ružmarin' or title_lower contains 'ruzmarin' or title_lower contains 'šampon' or title_lower contains 'sampon' or title_lower contains 'kosa' or title_lower contains 'mleko za kosu' or title_lower contains 'ulje za kosu' or title_lower contains 'voda za kosu' or title_lower contains 'rast kose' or title_lower contains 'jačanje kose' or title_lower contains 'opadanje kose' or title_lower contains 'sprej za kosu' or title_lower contains 'keratin' or title_lower contains 'vlasište' or title_lower contains 'vlasiste' or title_lower contains 'teme' or title_lower contains 'gusta kosa' or title_lower contains 'volumen' or tags_lower contains 'kosa' or tags_lower contains 'hair' or tags_lower contains 'ružmarin' or tags_lower contains 'ruzmarin' or collections_lower contains 'kosa' or collections_lower contains 'hair' -%}
          {%- assign product_category = 'hair' -%}
        {%- comment -%} Check for dental care products {%- endcomment -%}
        {%- elsif title_lower contains 'zub' or title_lower contains 'pasta za zube' or title_lower contains 'prah za zube' or title_lower contains 'izbeljivanje zuba' or title_lower contains 'beljenje zuba' or title_lower contains 'oralno' or title_lower contains 'ljubičast' or title_lower contains 'ljubicast' or title_lower contains 'ugljem' or title_lower contains 'uglja' or title_lower contains 'charcoal' or tags_lower contains 'zub' or tags_lower contains 'dental' or tags_lower contains 'oral' or collections_lower contains 'zub' or collections_lower contains 'dental' or collections_lower contains 'oral' -%}
          {%- assign product_category = 'dental' -%}
        {%- endif -%}
        
        "category": {{ product_category | json }},
        "questions": [
          {%- if product_category == 'hair' -%}
            "Kako se koristi?",
            "Koji sastojci su u proizvodu?",
            "Da li odgovara mom tipu kose?",
            "Koje su prednosti?",
            "Da li postoji set sa ovim proizvodom?"
          {%- elsif product_category == 'dental' -%}
            "Kako se koristi?",
            "Koji sastojci su u proizvodu?",
            "Da li je bezbedan za zube?",
            "Koliko često da koristim?",
            "Da li postoji set sa ovim proizvodom?"
          {%- else -%}
            "Kako se koristi?",
            "Koji sastojci su u proizvodu?",
            "Da li odgovara mom tipu kože?",
            "Koje su prednosti?",
            "Da li postoji set sa ovim proizvodom?"
          {%- endif -%}
        ]
      }
      {%- assign first_product = false -%}
    {%- endfor -%}
  },
  "generalQuestions": [
    "Ne znam šta da izaberem, možete li da mi pomognete?",
    "Imam suvu kožu, šta bi mi najviše prijalo?",
    "Kako da podstaknem rast i jačanje kose?",
    "Šta preporučujete za belje i zdravije zube?",
    "Kako da složim jednostavnu skincare rutinu?",
    "Imam masnu kožu, šta bi bilo dobro za mene?",
    "Koji proizvodi su najnežniji za osetljivu kožu?",
    "Kako da mi kosa bude jača i zdravija?",
    "Želim bundl ili set koji se najviše isplati, šta predlažete?"
  ]
}
</script>

