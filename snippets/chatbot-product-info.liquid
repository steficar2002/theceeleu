{%- comment -%}
  Chatbot Product Information and Instructions
  This file contains detailed product information and system instructions
  for the AI chatbot. It's used by both mobile and desktop chatbot variants.

  To add a new product:
  1. Product data is automatically generated from all products in the store
  2. Information is pulled from product descriptions and metafields
  3. Product-specific questions are generated automatically
{%- endcomment -%}

<script type="application/json" id="chatbot-product-info">
{
  "instructions": {
    "systemPrompt": "You are a helpful assistant and seller for {{ shop.name }}. Your goal is to help users find the right product for their skincare, hair growth, or oral health needs and encourage them to make a purchase. Answer questions about our products in English.",
    "rules": [
      "USE ONLY INFORMATION FROM THE PRODUCT SECTION ABOVE. NEVER make up information that is not listed!",
      "If you don't know the answer to the user's question, admit it and recommend that the user contacts support at email: help@ceel.rs",
      "Always respond in English",
      "ALWAYS use correct English spelling (grammar, capitalization, punctuation). Check every response before sending for grammatical correctness.",
      "Be friendly, relaxed, and professional in tone",
      "Be specific and helpful in your responses, but only based on the given information",
      "If the user asks about something that is not in the product information, say that you don't have that information and recommend contacting support at email: help@ceel.rs",
      "AS A SELLER: When the user shows interest in a product, naturally mention the advantages, benefits, and why the product is a good choice",
      "AS A SELLER: Mention current discounts, promotions, or special offers when relevant (if available in the product information)",
      "AS A SELLER: When natural, recommend multi-day supply packages as they offer better value and significant long-term savings",
      "AS A SELLER: Be enthusiastic about the products, but don't be aggressive or too pushy",
      "AS A SELLER: Focus on the user's needs and how the product can solve their problems",
      "AS A SELLER: At the end of the conversation, if natural, encourage the user to make a purchase and mention that the products are available immediately",
      "WHEN RECOMMENDING PRODUCTS: Analyze the user's problems (acne, dry skin, hair growth, oral health, etc.) and compare with the ingredients, categories, and usage of the products",
      "WHEN RECOMMENDING PRODUCTS: If products are available in a bundle, ALWAYS recommend the bundle as it is cheaper",
      "WHEN RECOMMENDING PRODUCTS: Recommend the 3-5 best products that match the user's needs",
      "WHEN RECOMMENDING PRODUCTS: Explain why each recommended product matches the user's problems",
      "SETS AND BUNDLES: If the user is viewing a product that exists in a set (containing_bundles), ALWAYS recommend the set and explain why the set is better - it's usually cheaper, provides complete care, and is better value",
      "SETS AND BUNDLES: When recommending a set, highlight specific benefits: saving money, more complete care, everything needed in one package, better value",
      "INGREDIENTS: When the user asks about ingredients, NEVER give the full list of all ingredients! Instead, extract and explain only the 3-5 MOST IMPORTANT ingredients with their explanations and benefits",
      "INGREDIENTS: Focus on active ingredients, key components, and those most important for the product's functionality (e.g., collagen, hyaluronic acid, retinol, vitamin C, etc.)",
      "INGREDIENTS: For each key ingredient explain: what it is, why it's good, how it helps the skin/hair, and why it's important in this product",
      "INGREDIENTS: Use information from 'ingredient_benefits' if available, or explain generally known benefits of the ingredients",
      "INGREDIENTS: If the user requests the complete list of ingredients, you can mention it, but first give explanations of the most important ones",
      "2+1 FREE OFFER: If the product has a 2+1 free offer (check in 'special_offers'), ALWAYS mention it as a better choice and explain why - they get the third product for free, which means greater savings",
      "2+1 FREE OFFER: When recommending a 2+1 offer, highlight the specific savings and value - e.g., 'Instead of buying 3 products at full price, you get the third one free, saving you X RSD'"
    ]
  },
  "products": {
    {%- assign first_product = true -%}
    {%- for product in collections.all.products -%}
      {%- unless first_product -%},{%- endunless -%}
      "{{ product.handle }}": {
        "title": {{ product.title | json }},
        "handle": {{ product.handle | json }},
        "description": {{ product.description | strip_html | json }},
        "price": {{ product.price | json }},
        "compare_at_price": {{ product.compare_at_price | default: null | json }},
        "vendor": {{ product.vendor | json }},
        "product_type": {{ product.type | json }},
        "tags": {{ product.tags | json }},
        "collections": [
          {%- for collection in product.collections -%}
            {{ collection.handle | json }}{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ],
        "ingredients": {{ product.metafields.custom.ingredients | default: '' | json }},
        "kako_se_koristi": {{ product.metafields.custom.kako_se_koristi | default: '' | json }},
        "active_ingredients": {{ product.metafields.custom.active_ingredients | default: '' | json }},
        "sastojci_detaljno": {{ product.metafields.custom.sastojci_detaljno | default: '' | json }},
        "upotreba_detaljno": {{ product.metafields.custom.upotreba_detaljno | default: '' | json }},
        "bundle_components": [
          {%- if product.metafields.custom.bundle_components.value -%}
            {%- assign first_component = true -%}
            {%- for component in product.metafields.custom.bundle_components.value -%}
              {%- unless first_component -%},{%- endunless -%}
              {
                "handle": {{ component.handle | json }},
                "title": {{ component.title | json }}
              }
              {%- assign first_component = false -%}
            {%- endfor -%}
          {%- endif -%}
        ],
        "containing_bundles": [
          {%- if product.metafields.custom.containing_bundles.value -%}
            {%- assign first_bundle = true -%}
            {%- for bundle in product.metafields.custom.containing_bundles.value -%}
              {%- unless first_bundle -%},{%- endunless -%}
              {
                "handle": {{ bundle.handle | json }},
                "title": {{ bundle.title | json }},
                "price": {{ bundle.price | json }}
              }
              {%- assign first_bundle = false -%}
            {%- endfor -%}
          {%- endif -%}
        ],
        "variants": [
          {%- assign first_variant = true -%}
          {%- for variant in product.variants -%}
            {%- unless first_variant -%},{%- endunless -%}
            {
              "id": {{ variant.id | json }},
              "title": {{ variant.title | json }},
              "price": {{ variant.price | json }},
              "compare_at_price": {{ variant.compare_at_price | default: null | json }},
              "available": {{ variant.available | json }},
              "sku": {{ variant.sku | default: '' | json }}
            }
            {%- assign first_variant = false -%}
          {%- endfor -%}
        ],
        {%- comment -%} Determine product category based on title, tags, and collections {%- endcomment -%}
        {%- assign product_category = 'skin' -%}
        {%- assign title_lower = product.title | downcase -%}
        {%- assign tags_lower = product.tags | join: ',' | downcase -%}
        {%- assign collections_lower = '' -%}
        {%- for collection in product.collections -%}
          {%- assign collections_lower = collections_lower | append: collection.handle | append: ',' -%}
        {%- endfor -%}
        {%- assign collections_lower = collections_lower | downcase -%}

        {%- comment -%} Check for hair care products {%- endcomment -%}
        {%- if title_lower contains 'ružmarin' or title_lower contains 'ruzmarin' or title_lower contains 'šampon' or title_lower contains 'sampon' or title_lower contains 'kosa' or title_lower contains 'mleko za kosu' or title_lower contains 'ulje za kosu' or title_lower contains 'voda za kosu' or title_lower contains 'rast kose' or title_lower contains 'jačanje kose' or title_lower contains 'opadanje kose' or title_lower contains 'sprej za kosu' or title_lower contains 'keratin' or title_lower contains 'vlasište' or title_lower contains 'vlasiste' or title_lower contains 'teme' or title_lower contains 'gusta kosa' or title_lower contains 'volumen' or tags_lower contains 'kosa' or tags_lower contains 'hair' or tags_lower contains 'ružmarin' or tags_lower contains 'ruzmarin' or collections_lower contains 'kosa' or collections_lower contains 'hair' -%}
          {%- assign product_category = 'hair' -%}
        {%- comment -%} Check for dental care products {%- endcomment -%}
        {%- elsif title_lower contains 'zub' or title_lower contains 'pasta za zube' or title_lower contains 'prah za zube' or title_lower contains 'izbeljivanje zuba' or title_lower contains 'beljenje zuba' or title_lower contains 'oralno' or title_lower contains 'ljubičast' or title_lower contains 'ljubicast' or title_lower contains 'ugljem' or title_lower contains 'uglja' or title_lower contains 'charcoal' or tags_lower contains 'zub' or tags_lower contains 'dental' or tags_lower contains 'oral' or collections_lower contains 'zub' or collections_lower contains 'dental' or collections_lower contains 'oral' -%}
          {%- assign product_category = 'dental' -%}
        {%- endif -%}

        "category": {{ product_category | json }},
        "questions": [
          {%- if product_category == 'hair' -%}
            "How do I use it?",
            "What ingredients are in the product?",
            "Is it suitable for my hair type?",
            "What are the benefits?",
            "Is there a set with this product?"
          {%- elsif product_category == 'dental' -%}
            "How do I use it?",
            "What ingredients are in the product?",
            "Is it safe for teeth?",
            "How often should I use it?",
            "Is there a set with this product?"
          {%- else -%}
            "How do I use it?",
            "What ingredients are in the product?",
            "Is it suitable for my skin type?",
            "What are the benefits?",
            "Is there a set with this product?"
          {%- endif -%}
        ]
      }
      {%- assign first_product = false -%}
    {%- endfor -%}
  },
  "generalQuestions": [
    "I don't know what to choose, can you help me?",
    "I have dry skin, what would suit me best?",
    "How can I promote hair growth and strength?",
    "What do you recommend for whiter and healthier teeth?",
    "How can I put together a simple skincare routine?",
    "I have oily skin, what would be good for me?",
    "Which products are the gentlest for sensitive skin?",
    "How can I make my hair stronger and healthier?",
    "I want a bundle or set that offers the best value, what do you suggest?"
  ]
}
</script>

