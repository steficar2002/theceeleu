{% doc %}
  @prompt
    I need a 3 block icon list with words underneath which clarifies that our products are Alcohol Free, Paraben free and Perfume free, 1. Let me change the font 2. let me hcange the icons. Make it more modern by having the 3 divs be in 3 cards with rounded corners
, I need to be able to change the svgs


{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    margin: {{ block.settings.margin }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-product-features-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.gap | divided_by: 2 }}px;
    }
  }

  .ai-product-feature-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    padding: {{ block.settings.card_padding }}px {{ block.settings.card_horizontal_padding }}px;
    background-color: {{ block.settings.card_background_color }};
    opacity: {{ block.settings.card_background_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid rgba(0, 0, 0, 0.2) !important;
    box-shadow: 0 {{ block.settings.card_shadow_size }}px {{ block.settings.card_shadow_size | times: 2 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.2s ease-in-out;
  }

  {% if block.settings.card_hover_effect %}
  .ai-product-feature-item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }
  {% endif %}

  .ai-product-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    color: {{ block.settings.icon_color }};
    opacity: {{ block.settings.icon_color_opacity | divided_by: 100.0 }};
    background-color: {{ block.settings.icon_background_color }};
    opacity: {{ block.settings.icon_background_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    padding: {{ block.settings.icon_padding }}px;
    background: rgba(255, 255, 255, 0.7) !important;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4) !important;
    box-shadow: 
      inset 3px 3px 12px 1px rgba(255, 216, 183, 0.25),
      inset -3px -3px 12px 1px rgba(244, 194, 255, 0.25),
      inset 3px -3px 12px 1px rgba(209, 189, 255, 0.25),
      inset -3px 3px 12px 1px rgba(160, 203, 255, 0.25),
      0 4px 8px 0 rgba(0, 0, 0, 0.08),
      0 8px 16px 0 rgba(0, 0, 0, 0.04),
      0 16px 32px 0 rgba(0, 0, 0, 0.02) !important;
  }

  .ai-product-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: #000000 !important;
    stroke: #000000 !important;
    color: #000000 !important;
  }

  .ai-product-feature-icon-{{ ai_gen_id }} svg * {
    fill: #000000 !important;
    stroke: #000000 !important;
    color: #000000 !important;
  }

  .ai-product-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.text_color_opacity | divided_by: 100.0 }};
    font-family: {{ block.settings.font_family }};
    padding: 0 {{ block.settings.text_horizontal_padding }}px;
    {% if block.settings.title_transform != 'none' %}
    text-transform: {{ block.settings.title_transform }};
    {% endif %}
  }

  .ai-product-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
    color: {{ block.settings.description_color }};
    opacity: {{ block.settings.description_color_opacity | divided_by: 100.0 }};
    font-family: {{ block.settings.font_family }};
    padding: 0 {{ block.settings.text_horizontal_padding }}px;
  }
{% endstyle %}

<div class="ai-product-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-feature-item-{{ ai_gen_id }}">
    <div class="ai-product-feature-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_1 != blank %}
        {{ block.settings.icon_1 }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 12H5a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2h-4"></path>
          <rect x="9" y="3" width="6" height="9" rx="1"></rect>
          <path d="M10 12v3"></path>
          <path d="M14 12v3"></path>
          <circle cx="12" cy="7" r="1"></circle>
        </svg>
      {% endif %}
    </div>
    <h3 class="ai-product-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
    <div class="ai-product-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_1_description }}</div>
  </div>

  <div class="ai-product-feature-item-{{ ai_gen_id }}">
    <div class="ai-product-feature-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_2 != blank %}
        {{ block.settings.icon_2 }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8.4 10.6a2.1 2.1 0 1 1 0 4.2 2.1 2.1 0 0 1 0-4.2"></path>
          <path d="M9.5 7.5V4a2 2 0 0 1 2-2h.5a2 2 0 0 1 2 2v3.5"></path>
          <path d="M14.5 7.5V4a2 2 0 0 1 2-2h.5a2 2 0 0 1 2 2v3.5"></path>
          <path d="M14.5 16.5V20a2 2 0 0 1-2 2h-.5a2 2 0 0 1-2-2v-3.5"></path>
          <path d="M14.5 16.5V20a2 2 0 0 0 2 2h.5a2 2 0 0 0 2-2v-3.5"></path>
          <path d="M3 8a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3z"></path>
        </svg>
      {% endif %}
    </div>
    <h3 class="ai-product-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
    <div class="ai-product-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_2_description }}</div>
  </div>

  <div class="ai-product-feature-item-{{ ai_gen_id }}">
    <div class="ai-product-feature-icon-{{ ai_gen_id }}">
      {% if block.settings.icon_3 != blank %}
        {{ block.settings.icon_3 }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="{{ block.settings.icon_size }}" height="{{ block.settings.icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21V10a5 5 0 0 1 5-5h.02M9 17h6m-6-4h6"></path>
          <path d="M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z"></path>
          <path d="m15 9-3-3-3 3"></path>
        </svg>
      {% endif %}
    </div>
    <h3 class="ai-product-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
    <div class="ai-product-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_3_description }}</div>
  </div>
</div>

