{% doc %}
  @prompt
    I need a section which has a subtitle and rounded corner colored background cards with an image overlaid and a heading inside the image with a subtitle below which is in the bottom left and then also buttons for paginated scrolling for mobile and also the ability to make clicking on the cards link to a product, All cards need different background colors also need adjustable card height (all card heights)


{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-cards-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: 40px 0;
  }

  .ai-image-cards__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 30px;
  }

  .ai-image-cards__subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.subtitle_color }};
    margin-bottom: 10px;
  }

  .ai-image-cards__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }

  .ai-image-cards__container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-image-cards__card-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 calc({{ 100 | divided_by: block.settings.cards_per_row }}% - {{ block.settings.gap | times: block.settings.cards_per_row | minus: block.settings.gap | divided_by: block.settings.cards_per_row }}px);
    min-width: 250px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    scroll-snap-align: start;
    transition: transform 0.3s;
  }

  .ai-image-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-image-cards__image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.card_height }}px;
    overflow: hidden;
  }

  .ai-image-cards__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-cards__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-image-cards__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-image-cards__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), rgba(0,0,0,0));
  }

  .ai-image-cards__card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: bold;
    color: {{ block.settings.card_title_color }};
    margin-bottom: 5px;
  }

  .ai-image-cards__card-subtitle-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.card_subtitle_color }};
  }

  .ai-image-cards__navigation-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 20px;
  }

  .ai-image-cards__nav-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .ai-image-cards__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-image-cards__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 749px) {
    .ai-image-cards__card-{{ ai_gen_id }} {
      flex: 0 0 calc({{ 100 | divided_by: block.settings.cards_per_row_mobile }}% - {{ block.settings.gap | times: block.settings.cards_per_row_mobile | minus: block.settings.gap | divided_by: block.settings.cards_per_row_mobile }}px);
    }
  }
{% endstyle %}

<image-cards-{{ ai_gen_id }} class="ai-image-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-cards__header-{{ ai_gen_id }}">
    {% if block.settings.subtitle != blank %}
      <div class="ai-image-cards__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>

  <div class="ai-image-cards__container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign subtitle_key = 'subtitle_' | append: i
        assign link_key = 'link_' | append: i
        assign product_key = 'product_' | append: i
        assign bg_color_key = 'card_bg_color_' | append: i
        assign image = block.settings[image_key]
        assign title = block.settings[title_key]
        assign subtitle = block.settings[subtitle_key]
        assign link = block.settings[link_key]
        assign product = block.settings[product_key]
        assign bg_color = block.settings[bg_color_key]
      %}

      {% if title != blank or image != blank or product != blank %}
        {% assign card_url = link %}
        {% if product != blank %}
          {% assign card_url = product.url %}
        {% endif %}
        <a href="{{ card_url }}" class="ai-image-cards__card-{{ ai_gen_id }}" style="background-color: {{ bg_color }};">
          <div class="ai-image-cards__image-container-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 800 }}" 
                alt="{{ image.alt | escape }}" 
                class="ai-image-cards__image-{{ ai_gen_id }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="ai-image-cards__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-image-cards__content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-image-cards__card-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% elsif product != blank %}
              <h3 class="ai-image-cards__card-title-{{ ai_gen_id }}">{{ product.title }}</h3>
            {% endif %}

            {% if subtitle != blank %}
              <div class="ai-image-cards__card-subtitle-{{ ai_gen_id }}">{{ subtitle }}</div>
            {% elsif product != blank and product.price %}
              <div class="ai-image-cards__card-subtitle-{{ ai_gen_id }}">{{ product.price | money }}</div>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
  
  <div class="ai-image-cards__navigation-{{ ai_gen_id }}">
    <button class="ai-image-cards__nav-button-{{ ai_gen_id }} ai-image-cards__prev-{{ ai_gen_id }}" aria-label="Previous">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="ai-image-cards__nav-button-{{ ai_gen_id }} ai-image-cards__next-{{ ai_gen_id }}" aria-label="Next">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</image-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCards extends HTMLElement {
      constructor() {
        super();
        this.container = this.querySelector('.ai-image-cards__container-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-cards__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-cards__next-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-image-cards__card-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateButtonState();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.scrollPrev());
        this.nextButton.addEventListener('click', () => this.scrollNext());
        this.container.addEventListener('scroll', () => this.updateButtonState());
      }

      scrollPrev() {
        const cardWidth = this.cards[0].offsetWidth + {{ block.settings.gap }};
        this.container.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      }

      scrollNext() {
        const cardWidth = this.cards[0].offsetWidth + {{ block.settings.gap }};
        this.container.scrollBy({ left: cardWidth, behavior: 'smooth' });
      }

      updateButtonState() {
        const isAtStart = this.container.scrollLeft <= 0;
        const isAtEnd = this.container.scrollLeft + this.container.offsetWidth >= this.container.scrollWidth - 1;

        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }
    }

    customElements.define('image-cards-{{ ai_gen_id }}', ImageCards);
  })();
</script>

