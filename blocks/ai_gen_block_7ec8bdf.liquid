{% doc %}
  @prompt
    Create a social proof section with infinitely scrolling images in 9:16 portrait format. The section should display customer photos in a continuous horizontal scroll that loops infinitely, showcasing user-generated content or testimonials., I want two titles, one will be for digits and I want a nice glowing effect, then the second title should be smaller.
, Let's add a second title and make both of these titles have selectable sizes from the typography presets
, I also want to be able to change the fonts
, The font selections are being overridden by the font settings, instead of selecting the font use typography settings similar to the other sections


{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-social-proof-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
    width: 100%;
    padding: {{ block.settings.padding_vertical }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-social-proof-titles-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    max-width: {{ block.settings.text_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-social-proof-main-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    margin: {{ block.settings.main_title_margin_top }}px {{ block.settings.main_title_margin_horizontal }}px {{ block.settings.main_title_margin_bottom }}px;
    line-height: 1.2;
    font-family: {{ block.settings.title_font }} !important;
  }

  .ai-social-proof-main-title-{{ ai_gen_id }} .digit {
    color: #000000;
    text-shadow: 
      /* Gradient-like effect using text-shadow */
      0 0 1px rgba(0, 0, 0, 0.8),
      0 0 2px rgba(0, 0, 0, 0.8),
      0 0 3px rgba(0, 0, 0, 0.8),
      /* Primary 3D effect - closer to text */
      -1px -1px 0 rgba(255, 255, 255, 0.8),
      1px -1px 0 rgba(255, 255, 255, 0.8),
      -1px 1px 0 rgba(255, 255, 255, 0.8),
      1px 1px 0 rgba(255, 255, 255, 0.8),
      /* Secondary 3D effect - middle distance */
      -2px -2px 0 rgba(255, 255, 255, 0.6),
      2px -2px 0 rgba(255, 255, 255, 0.6),
      -2px 2px 0 rgba(255, 255, 255, 0.6),
      2px 2px 0 rgba(255, 255, 255, 0.6),
      /* Tertiary 3D effect - further out */
      -3px -3px 0 rgba(255, 255, 255, 0.4),
      3px -3px 0 rgba(255, 255, 255, 0.4),
      -3px 3px 0 rgba(255, 255, 255, 0.4),
      3px 3px 0 rgba(255, 255, 255, 0.4),
      /* Glow effect */
      0 0 8px rgba(255, 216, 183, 0.3),
      0 0 16px rgba(244, 194, 255, 0.3),
      0 0 24px rgba(209, 189, 255, 0.3),
      0 0 32px rgba(160, 203, 255, 0.3);
    font-weight: bold;
    font-family: {{ block.settings.title_font }} !important;
    animation: glow-rotate-{{ ai_gen_id }} {{ block.settings.glow_animation_speed }}s ease-in-out infinite;
    position: relative;
    z-index: 1;
  }

  @keyframes glow-rotate-{{ ai_gen_id }} {
