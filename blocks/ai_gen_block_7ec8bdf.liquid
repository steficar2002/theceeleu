        /* Primary 3D effect - closer to text */
        -1px -1px 0 rgba(255, 255, 255, 0.8),
        1px -1px 0 rgba(255, 255, 255, 0.8),
        -1px 1px 0 rgba(255, 255, 255, 0.8),
        1px 1px 0 rgba(255, 255, 255, 0.8),
        /* Secondary 3D effect - middle distance */
        -2px -2px 0 rgba(255, 255, 255, 0.6),
        2px -2px 0 rgba(255, 255, 255, 0.6),
        -2px 2px 0 rgba(255, 255, 255, 0.6),
        2px 2px 0 rgba(255, 255, 255, 0.6),
        /* Tertiary 3D effect - further out */
        -3px -3px 0 rgba(255, 255, 255, 0.4),
        3px -3px 0 rgba(255, 255, 255, 0.4),
        -3px 3px 0 rgba(255, 255, 255, 0.4),
        3px 3px 0 rgba(255, 255, 255, 0.4),
        /* Glow effect */
        0 0 8px rgba(255, 216, 183, 0.3),
        0 0 16px rgba(244, 194, 255, 0.3),
        0 0 24px rgba(209, 189, 255, 0.3),
        0 0 32px rgba(160, 203, 255, 0.3);
    }
    25% {
      text-shadow: 
        /* Primary 3D effect - closer to text */
        -1px -1px 0 rgba(255, 255, 255, 0.8),
        1px -1px 0 rgba(255, 255, 255, 0.8),
        -1px 1px 0 rgba(255, 255, 255, 0.8),
        1px 1px 0 rgba(255, 255, 255, 0.8),
        /* Secondary 3D effect - middle distance */
        -2px -2px 0 rgba(255, 255, 255, 0.6),
        2px -2px 0 rgba(255, 255, 255, 0.6),
        -2px 2px 0 rgba(255, 255, 255, 0.6),
        2px 2px 0 rgba(255, 255, 255, 0.6),
        /* Tertiary 3D effect - further out */
        -3px -3px 0 rgba(255, 255, 255, 0.4),
        3px -3px 0 rgba(255, 255, 255, 0.4),
        -3px 3px 0 rgba(255, 255, 255, 0.4),
        3px 3px 0 rgba(255, 255, 255, 0.4),
        /* Glow effect */
        0 0 8px rgba(244, 194, 255, 0.3),
        0 0 16px rgba(209, 189, 255, 0.3),
        0 0 24px rgba(160, 203, 255, 0.3),
        0 0 32px rgba(255, 216, 183, 0.3);
    }
    50% {
      text-shadow: 
        /* Primary 3D effect - closer to text */
        -1px -1px 0 rgba(255, 255, 255, 0.8),
        1px -1px 0 rgba(255, 255, 255, 0.8),
        -1px 1px 0 rgba(255, 255, 255, 0.8),
        1px 1px 0 rgba(255, 255, 255, 0.8),
        /* Secondary 3D effect - middle distance */
        -2px -2px 0 rgba(255, 255, 255, 0.6),
        2px -2px 0 rgba(255, 255, 255, 0.6),
        -2px 2px 0 rgba(255, 255, 255, 0.6),
        2px 2px 0 rgba(255, 255, 255, 0.6),
        /* Tertiary 3D effect - further out */
        -3px -3px 0 rgba(255, 255, 255, 0.4),
        3px -3px 0 rgba(255, 255, 255, 0.4),
        -3px 3px 0 rgba(255, 255, 255, 0.4),
        3px 3px 0 rgba(255, 255, 255, 0.4),
        /* Glow effect */
        0 0 8px rgba(209, 189, 255, 0.3),
        0 0 16px rgba(160, 203, 255, 0.3),
        0 0 24px rgba(255, 216, 183, 0.3),
        0 0 32px rgba(244, 194, 255, 0.3);
    }
    75% {
      text-shadow: 
        /* Primary 3D effect - closer to text */
        -1px -1px 0 rgba(255, 255, 255, 0.8),
        1px -1px 0 rgba(255, 255, 255, 0.8),
        -1px 1px 0 rgba(255, 255, 255, 0.8),
        1px 1px 0 rgba(255, 255, 255, 0.8),
        /* Secondary 3D effect - middle distance */
        -2px -2px 0 rgba(255, 255, 255, 0.6),
        2px -2px 0 rgba(255, 255, 255, 0.6),
        -2px 2px 0 rgba(255, 255, 255, 0.6),
        2px 2px 0 rgba(255, 255, 255, 0.6),
        /* Tertiary 3D effect - further out */
        -3px -3px 0 rgba(255, 255, 255, 0.4),
        3px -3px 0 rgba(255, 255, 255, 0.4),
        -3px 3px 0 rgba(255, 255, 255, 0.4),
        3px 3px 0 rgba(255, 255, 255, 0.4),
        /* Glow effect */
        0 0 8px rgba(160, 203, 255, 0.3),
        0 0 16px rgba(255, 216, 183, 0.3),
        0 0 24px rgba(244, 194, 255, 0.3),
        0 0 32px rgba(209, 189, 255, 0.3);
    }
    100% {
      text-shadow: 
        /* Primary 3D effect - closer to text */
        -1px -1px 0 rgba(255, 255, 255, 0.8),
        1px -1px 0 rgba(255, 255, 255, 0.8),
        -1px 1px 0 rgba(255, 255, 255, 0.8),
        1px 1px 0 rgba(255, 255, 255, 0.8),
        /* Secondary 3D effect - middle distance */
        -2px -2px 0 rgba(255, 255, 255, 0.6),
        2px -2px 0 rgba(255, 255, 255, 0.6),
        -2px 2px 0 rgba(255, 255, 255, 0.6),
        2px 2px 0 rgba(255, 255, 255, 0.6),
        /* Tertiary 3D effect - further out */
        -3px -3px 0 rgba(255, 255, 255, 0.4),
        3px -3px 0 rgba(255, 255, 255, 0.4),
        -3px 3px 0 rgba(255, 255, 255, 0.4),
        3px 3px 0 rgba(255, 255, 255, 0.4),
        /* Glow effect */
        0 0 8px rgba(255, 216, 183, 0.3),
        0 0 16px rgba(244, 194, 255, 0.3),
