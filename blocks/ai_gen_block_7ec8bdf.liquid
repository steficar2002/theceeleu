  .ai-social-proof-second-title-{{ ai_gen_id }} {
    color: {{ block.settings.second_title_color }};
    margin: {{ block.settings.second_title_margin_top }}px {{ block.settings.second_title_margin_horizontal }}px {{ block.settings.second_title_margin_bottom }}px;
    line-height: 1.2;
    font-family: {{ block.settings.second_title_font }} !important;
  }

  .ai-social-proof-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    margin: {{ block.settings.subtitle_margin_top }}px {{ block.settings.subtitle_margin_horizontal }}px {{ block.settings.subtitle_margin_bottom }}px;
    line-height: 1.2;
  }

  .ai-social-proof-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
  }

  .ai-social-proof-images-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    animation: scroll-{{ ai_gen_id }} linear infinite;
    animation-duration: {{ block.settings.scroll_speed }}s;
  }

  .ai-social-proof-images-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-social-proof-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.image_width }}px;
    height: calc({{ block.settings.image_width }}px * 16 / 9);
    flex-shrink: 0;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-social-proof-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-social-proof-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-social-proof-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.5;
  }

  @keyframes scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-social-proof-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_width_mobile }}px;
      height: calc({{ block.settings.image_width_mobile }}px * 16 / 9);
    }
  }
{% endstyle %}

<div class="ai-social-proof-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-social-proof-titles-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-social-proof-main-title-{{ ai_gen_id }} {{ block.settings.title_typography }}">
        {% assign title_parts = block.settings.title | split: ' ' %}
        {% for part in title_parts %}
          {% if part contains '#' %}
            {% assign clean_part = part | remove: '#' %}
            <span class="digit">{{ clean_part }}</span>
          {% else %}
            {{ part }}
          {% endif %}
          {% unless forloop.last %} {% endunless %}
        {% endfor %}
      </div>
    {% endif %}
    {% if block.settings.second_title != blank %}
      <div class="ai-social-proof-second-title-{{ ai_gen_id }} {{ block.settings.second_title_typography }}">
        {{ block.settings.second_title }}
      </div>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <div class="ai-social-proof-subtitle-{{ ai_gen_id }} {{ block.settings.subtitle_typography }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>
  
  <div class="ai-social-proof-track-{{ ai_gen_id }}">
    <div class="ai-social-proof-images-{{ ai_gen_id }}">
      {% for i in (1..block.settings.image_count) %}
        {% assign image_key = 'image_' | append: i %}
        <div class="ai-social-proof-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings[image_key] %}
            <img 
              src="{{ block.settings[image_key] | image_url: width: 400 }}"
              alt="{{ block.settings[image_key].alt | escape }}"
              loading="lazy"
              class="ai-social-proof-image-{{ ai_gen_id }}"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_width | times: 16 | divided_by: 9 }}"
            >
          {% else %}
            <div class="ai-social-proof-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
      
      {% comment %} Duplicate images for infinite scroll effect {% endcomment %}
      {% for i in (1..block.settings.image_count) %}
        {% assign image_key = 'image_' | append: i %}
        <div class="ai-social-proof-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings[image_key] %}
            <img 
              src="{{ block.settings[image_key] | image_url: width: 400 }}"
              alt="{{ block.settings[image_key].alt | escape }}"
              loading="lazy"
              class="ai-social-proof-image-{{ ai_gen_id }}"
              width="{{ block.settings.image_width }}"
              height="{{ block.settings.image_width | times: 16 | divided_by: 9 }}"
            >
          {% else %}
            <div class="ai-social-proof-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

