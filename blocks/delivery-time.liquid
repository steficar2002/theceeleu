{% doc %}
  Delivery Time Block - Shows estimated delivery time with English date formatting
  Calculates 2-3 working days from current day, considering 12pm cutoff
{% enddoc %}

{% assign delivery_block_id = block.id | replace: '_', '' | downcase %}

{% comment %} Calculate delivery dates {% endcomment %}
{% assign current_time = 'now' | date: '%H' | plus: 0 %}
{% assign is_after_12pm = false %}
{% if current_time >= 12 %}
  {% assign is_after_12pm = true %}
{% endif %}

{% comment %} English day names {% endcomment %}
{% assign english_days = 'Sunday,Monday,Tuesday,Wednesday,Thursday,Friday,Saturday' | split: ',' %}
{% assign english_months = 'Jan,Feb,Mar,Apr,May,Jun,Jul,Aug,Sep,Oct,Nov,Dec' | split: ',' %}

{% comment %} Calculate delivery date (2-3 working days) {% endcomment %}
{% assign delivery_days = 2 %}
{% if is_after_12pm %}
  {% assign delivery_days = 3 %}
{% endif %}

{% comment %} Add working days (skip weekends) {% endcomment %}
{% assign delivery_date = 'now' | date: '%s' | plus: 86400 %}
{% assign working_days_added = 0 %}
{% for i in (1..10) %}
  {% if working_days_added >= delivery_days %}
    {% break %}
  {% endif %}
  {% assign check_date = delivery_date | date: '%w' | plus: 0 %}
  {% if check_date != 0 and check_date != 6 %}
    {% assign working_days_added = working_days_added | plus: 1 %}
  {% endif %}
  {% if working_days_added < delivery_days %}
    {% assign delivery_date = delivery_date | plus: 86400 %}
  {% endif %}
{% endfor %}

{% comment %} Format delivery date {% endcomment %}
{% assign delivery_day_of_week = delivery_date | date: '%w' | plus: 0 %}
{% assign delivery_month = delivery_date | date: '%m' | plus: 0 | minus: 1 %}
{% assign delivery_day = delivery_date | date: '%d' | plus: 0 %}
{% assign delivery_month_name = english_months[delivery_month] %}
{% assign delivery_day_name = english_days[delivery_day_of_week] %}

{% comment %} Format current time {% endcomment %}
{% assign current_hour = 'now' | date: '%H' %}
{% assign current_minute = 'now' | date: '%M' %}
{% assign current_time_formatted = current_hour | append: ':' | append: current_minute %}

{% style %}
  .delivery-time-{{ delivery_block_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.card_padding }}px {{ block.settings.card_horizontal_padding }}px;
    background-color: {{ block.settings.card_background_color }};
    opacity: {{ block.settings.card_background_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid rgba(0, 0, 0, 0.2) !important;
    box-shadow: 0 {{ block.settings.card_shadow_size }}px {{ block.settings.card_shadow_size | times: 2 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.2s ease-in-out;
    margin: {{ block.settings.margin }}px 0;
    max-width: {{ block.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  {% if block.settings.card_hover_effect %}
  .delivery-time-{{ delivery_block_id }}:hover {
    transform: translateY(-2px);
  }
  {% endif %}

  .delivery-time-title-{{ delivery_block_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin-bottom: {{ block.settings.title_margin_bottom }}px;
    color: {{ block.settings.title_color }};
    opacity: {{ block.settings.title_color_opacity | divided_by: 100.0 }};
    font-family: {{ block.settings.font_family }};
    {% if block.settings.title_transform != 'none' %}
    text-transform: {{ block.settings.title_transform }};
    {% endif %}
  }

  .delivery-timeline-{{ delivery_block_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin: {{ block.settings.timeline_margin }}px 0;
    position: relative;
  }

  .delivery-timeline-line-{{ delivery_block_id }} {
    position: absolute;
    top: 50%;
    left: 15%;
    right: 15%;
    height: 2px;
    background-color: {{ block.settings.timeline_color }};
    opacity: {{ block.settings.timeline_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  .delivery-step-{{ delivery_block_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
    position: relative;
    flex: 1;
  }

  .delivery-step-icon-{{ delivery_block_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_margin_bottom }}px;
    color: {{ block.settings.icon_color }};
    background: rgba(255, 255, 255, 0.7) !important;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4) !important;
    box-shadow: 
      inset 3px 3px 12px 1px rgba(255, 216, 183, 0.25),
      inset -3px -3px 12px 1px rgba(244, 194, 255, 0.25),
      inset 3px -3px 12px 1px rgba(209, 189, 255, 0.25),
      inset -3px 3px 12px 1px rgba(160, 203, 255, 0.25),
      0 4px 8px 0 rgba(0, 0, 0, 0.08),
      0 8px 16px 0 rgba(0, 0, 0, 0.04),
      0 16px 32px 0 rgba(0, 0, 0, 0.02) !important;
    border-radius: {{ block.settings.icon_border_radius }}px;
    padding: {{ block.settings.icon_padding }}px;
  }

  .delivery-step-icon-{{ delivery_block_id }} {
    color: #000000 !important;
  }

  .delivery-step-icon-{{ delivery_block_id }} svg {
    width: 100%;
    height: 100%;
    stroke: none !important;
  }

  .delivery-step-icon-{{ delivery_block_id }} svg * {
    fill: currentColor;
    stroke: none !important;
  }

  .delivery-step-icon-{{ delivery_block_id }} svg[fill="none"],
  .delivery-step-icon-{{ delivery_block_id }} svg[fill="none"] *,
  .delivery-step-icon-{{ delivery_block_id }} svg *[fill="none"] {
    fill: none !important;
  }

  .delivery-step-icon-{{ delivery_block_id }} svg[stroke="none"],
  .delivery-step-icon-{{ delivery_block_id }} svg[stroke="none"] *,
  .delivery-step-icon-{{ delivery_block_id }} svg *[stroke="none"] {
    stroke: none !important;
  }

  .delivery-step-text-{{ delivery_block_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    opacity: {{ block.settings.text_color_opacity | divided_by: 100.0 }};
    font-family: {{ block.settings.font_family }};
    line-height: 1.3;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .delivery-time-{{ delivery_block_id }} {
      padding: {{ block.settings.card_padding | divided_by: 2 }}px {{ block.settings.card_horizontal_padding | divided_by: 2 }}px;
    }
    
    .delivery-timeline-{{ delivery_block_id }} {
      flex-direction: row;
      gap: {{ block.settings.mobile_gap | minus: 4 }}px;
      overflow-x: visible;
    }
    
    .delivery-timeline-line-{{ delivery_block_id }} {
      display: block;
      left: 15%;
      right: 15%;
    }
    
    .delivery-step-text-{{ delivery_block_id }} {
      font-size: {{ block.settings.text_size | minus: 2 }}px;
    }
  }
{% endstyle %}

<div class="delivery-time-{{ delivery_block_id }}" {{ block.shopify_attributes }}>
  <h3 class="delivery-time-title-{{ delivery_block_id }}">{{ block.settings.title | default: 'Vreme Dostave' }}</h3>
  
  <div class="delivery-timeline-{{ delivery_block_id }}">
    <div class="delivery-timeline-line-{{ delivery_block_id }}"></div>
    
    <div class="delivery-step-{{ delivery_block_id }}">
      <div class="delivery-step-icon-{{ delivery_block_id }}">
        {% if block.settings.icon_1 != blank %}
          {{ block.settings.icon_1 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12,6 12,12 16,14"></polyline>
          </svg>
        {% endif %}
      </div>
      <div class="delivery-step-text-{{ delivery_block_id }}">danas {{ current_time_formatted }}</div>
    </div>
    
    <div class="delivery-step-{{ delivery_block_id }}">
      <div class="delivery-step-icon-{{ delivery_block_id }}">
        {% if block.settings.icon_2 != blank %}
          {{ block.settings.icon_2 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <rect x="1" y="3" width="15" height="13"></rect>
            <path d="M16 8h.01"></path>
            <path d="M16 12h.01"></path>
            <path d="M16 16h.01"></path>
            <path d="M5 21v-7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v7"></path>
          </svg>
        {% endif %}
      </div>
      <div class="delivery-step-text-{{ delivery_block_id }}">
        {% if is_after_12pm %}
          3 radna dana
        {% else %}
          2-3 radna dana
        {% endif %}
      </div>
    </div>
    
    <div class="delivery-step-{{ delivery_block_id }}">
      <div class="delivery-step-icon-{{ delivery_block_id }}">
        {% if block.settings.icon_3 != blank %}
          {{ block.settings.icon_3 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        {% endif %}
      </div>
      <div class="delivery-step-text-{{ delivery_block_id }}">{{ delivery_day_name }}, {{ delivery_day }}. {{ delivery_month_name }}.</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Delivery Time",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Vreme Dostave"
    },
    {
      "type": "liquid",
      "id": "icon_1",
      "label": "Clock Icon SVG",
      "info": "Paste SVG code for the clock icon. Default icon will be used if empty."
    },
    {
      "type": "liquid",
      "id": "icon_2",
      "label": "Truck Icon SVG",
      "info": "Paste SVG code for the truck icon. Default icon will be used if empty."
    },
    {
      "type": "liquid",
      "id": "icon_3",
      "label": "Location Icon SVG",
      "info": "Paste SVG code for the location icon. Default icon will be used if empty."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 500
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Card vertical padding",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_horizontal_padding",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Card horizontal padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#f8f9fa"
    },
    {
      "type": "range",
      "id": "card_background_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Card background opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "card_shadow_size",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Card shadow size",
      "default": 5
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "%",
      "label": "Card shadow opacity",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "card_hover_effect",
      "label": "Enable hover effect",
      "default": true
    },
    {
      "type": "range",
      "id": "margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical margin",
      "default": 20
    },
    {
      "type": "header",
      "content": "Timeline"
    },
    {
      "type": "range",
      "id": "timeline_margin",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Timeline margin",
      "default": 20
    },
    {
      "type": "color",
      "id": "timeline_color",
      "label": "Timeline line color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "timeline_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Timeline opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "min": 10,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Mobile gap between steps",
      "default": 15
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Icon size",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_padding",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Icon padding",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Icon border radius",
      "default": 50
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "icon_margin_bottom",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Icon margin bottom",
      "default": 10
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "options": [
        {
          "value": "var(--type-body-font)",
          "label": "Body font"
        },
        {
          "value": "var(--type-heading-font)",
          "label": "Heading font"
        },
        {
          "value": "var(--type-accent-font)",
          "label": "Accent font"
        }
      ],
      "default": "var(--type-body-font)"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 20
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Title text case",
      "options": [
        {
          "value": "none",
          "label": "Normal"
        },
        {
          "value": "uppercase",
          "label": "UPPERCASE"
        },
        {
          "value": "lowercase",
          "label": "lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "title_color_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Title color opacity",
      "default": 100
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "text_color_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Text color opacity",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Delivery Time"
    }
  ]
}
{% endschema %}
