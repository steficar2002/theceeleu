<style>
    .custom-product-finder-{{ section.id }} {
      --font-heading: 'Poppins', {{ section.settings.font_heading.family }}, {{ section.settings.font_heading.fallback_families }};
      --font-body: 'Poppins', {{ section.settings.font_body.family }}, {{ section.settings.font_body.fallback_families }};
  
      --heading-font-size: {{ section.settings.heading_font_size }}px;
      --heading-font-weight: {{ section.settings.font_heading.weight }};
      --subheading-font-size: {{ section.settings.subheading_font_size }}px;
      --subheading-font-weight: {{ section.settings.font_body.weight }};
  
      --form-label-font-size: {{ section.settings.form_label_font_size }}px;
      --form-label-font-weight: {{ section.settings.font_body.weight }};
  
      --button-font-size: {{ section.settings.button_font_size }}px;
      --button-font-weight: {{ section.settings.font_body.weight }};
      
      background-color: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
      padding: 50px 0;
    }
  
    .custom-product-finder-{{ section.id }} .page-width {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: center;
    }
  
    .custom-product-finder-{{ section.id }} .text-content {
      text-align: left;
    }
  
    .custom-product-finder-{{ section.id }} .heading {
      font-family: var(--font-heading);
      font-size: var(--heading-font-size);
      font-weight: var(--heading-font-weight);
      margin: 0 0 15px 0;
    }
  
    .custom-product-finder-{{ section.id }} .subheading {
      font-family: var(--font-body);
      font-size: var(--subheading-font-size);
      font-weight: var(--subheading-font-weight);
      margin: 0;
    }
  
    .custom-product-finder-{{ section.id }} .form-container {
      padding: 40px;
      border: 1px solid #e0e0e0;
      border-radius: 5px;
    }
    
    .custom-product-finder-{{ section.id }} .form-group {
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
    }
  
    .custom-product-finder-{{ section.id }} .form-label {
        font-family: var(--font-body);
        font-size: var(--form-label-font-size);
        font-weight: var(--form-label-font-weight);
        display: inline-block;
        margin-right: 10px;
    }
  
    .custom-product-finder-{{ section.id }} .custom-select {
      width: 100%;
      padding: 10px 0;
      border: none;
      border-bottom: 1px solid #ccc;
      background-color: transparent;
      font-size: var(--form-label-font-size);
      font-family: var(--font-body);
      cursor: pointer;
      flex: 1;
    }
    
    .custom-product-finder-{{ section.id }} .custom-select:focus {
      outline: none;
      border-bottom: 2px solid {{ section.settings.text_color }};
    }
  
    .custom-product-finder-{{ section.id }} .cta-button {
      font-family: var(--font-body);
      font-size: var(--button-font-size);
      font-weight: var(--button-font-weight);
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: 
        inset 3px 3px 12px 1px rgba(255, 216, 183, 0.25),
        inset -3px -3px 12px 1px rgba(244, 194, 255, 0.25),
        inset 3px -3px 12px 1px rgba(209, 189, 255, 0.25),
        0 4px 8px rgba(0, 0, 0, 0.1);
      color: {{ section.settings.button_text_color }};
      padding: 12px 30px;
      border-radius: 50px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      text-align: center;
      transition: all 0.3s ease;
    }
  
    .custom-product-finder-{{ section.id }} .cta-button:hover {
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.25);
      box-shadow: 
        inset 4px 4px 16px 2px rgba(255, 216, 183, 0.45),
        inset -4px -4px 16px 2px rgba(244, 194, 255, 0.45),
        inset 4px -4px 16px 2px rgba(209, 189, 255, 0.35),
        0 6px 12px rgba(0, 0, 0, 0.15);
    }
    
    .custom-product-finder-{{ section.id }} .cta-button.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }
    
    .custom-product-finder-{{ section.id }} .full-form-group {
      display: block;
      margin-bottom: 20px;
    }
    
    .custom-product-finder-{{ section.id }} .full-form-group .form-label {
      text-align: left;
      display: block;
      margin-bottom: 5px;
    }
    
    .custom-product-finder-{{ section.id }} .product-preview {
      display: none;
      margin-top: 20px;
      text-align: center;
    }
    
    .custom-product-finder-{{ section.id }} .product-preview.show {
      display: block;
    }
    
    .custom-product-finder-{{ section.id }} .product-image {
      max-width: 200px;
      height: auto;
      border-radius: 8px;
      margin: 0 auto 10px auto;
      display: block;
    }
    
    .custom-product-finder-{{ section.id }} .product-title {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 600;
      margin: 0;
    }
  
    @media (max-width: 768px) {
      .custom-product-finder-{{ section.id }} .page-width {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 20px;
      }
      .custom-product-finder-{{ section.id }} .text-content {
        text-align: center;
        margin-bottom: 30px;
      }
      .custom-product-finder-{{ section.id }} .form-container {
        padding: 20px;
      }
      .custom-product-finder-{{ section.id }} .form-group {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }
      .custom-product-finder-{{ section.id }} .form-label {
        margin-right: 0;
        margin-bottom: 5px;
      }
      .custom-product-finder-{{ section.id }} .custom-select {
        width: 100%;
      }
      .custom-product-finder-{{ section.id }} .product-image {
        max-width: 150px;
      }
    }
    
    @media (max-width: 480px) {
      .custom-product-finder-{{ section.id }} {
        padding: 30px 0;
      }
      .custom-product-finder-{{ section.id }} .page-width {
        padding: 0 15px;
      }
      .custom-product-finder-{{ section.id }} .form-container {
        padding: 15px;
      }
    }
  </style>
  
  <div class="custom-product-finder-{{ section.id }}">
    <div class="page-width">
      <div class="text-content">
        <h2 class="heading">{{ section.settings.heading }}</h2>
        <p class="subheading">{{ section.settings.subheading }}</p>
      </div>
      <div class="form-container">
        <div class="form-group">
          <label for="product-type-{{ section.id }}" class="form-label">{{ section.settings.product_type_label }}</label>
          <select id="product-type-{{ section.id }}" class="custom-select">
            <option value="" disabled selected>{{ section.settings.product_type_placeholder }}</option>
            {%- assign product_types_list = "" -%}
            {%- for block in section.blocks -%}
              {%- assign current_type = block.settings.product_type | strip -%}
              {%- unless product_types_list contains current_type -%}
                {%- if product_types_list == blank -%}
                  {%- assign product_types_list = current_type -%}
                {%- else -%}
                  {%- assign product_types_list = product_types_list | append: "|" | append: current_type -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
            {%- assign unique_product_types = product_types_list | split: "|" -%}
            
            {%- comment -%} Fallback product types if no blocks are configured {%- endcomment -%}
            {%- if unique_product_types.size == 0 or unique_product_types == blank -%}
              <option value="Serum">Serum</option>
              <option value="Krema">Krema</option>
              <option value="Maska">Maska</option>
              <option value="Čistač">Čistač</option>
              <option value="Tonik">Tonik</option>
              <option value="Ulje za kosu">Ulje za kosu</option>
              <option value="Šampon">Šampon</option>
              <option value="Mleko za kosu">Mleko za kosu</option>
              <option value="Tretman za kosu">Tretman za kosu</option>
              <option value="Pasta za zube">Pasta za zube</option>
              <option value="Prah za zube">Prah za zube</option>
              <option value="Set">Set</option>
            {%- else -%}
              {%- for type in unique_product_types -%}
                <option value="{{ type | escape }}">{{ type | escape }}</option>
              {%- endfor -%}
            {%- endif -%}
          </select>
        </div>
  
        <div class="full-form-group">
          <label for="concern-{{ section.id }}" class="form-label">{{ section.settings.concern_label }}</label>
          <select id="concern-{{ section.id }}" class="custom-select" disabled>
            <option value="" disabled selected>{{ section.settings.concern_placeholder }}</option>
          </select>
        </div>
  
        <a href="#" id="cta-button-{{ section.id }}" class="cta-button disabled">
          {{ section.settings.button_text }}
        </a>
        
        <div id="product-preview-{{ section.id }}" class="product-preview">
          <img id="product-image-{{ section.id }}" class="product-image" src="" alt="" width="200" height="200" style="display: none;">
          <h3 id="product-title-{{ section.id }}" class="product-title"></h3>
        </div>
      </div>
    </div>
  </div>
  
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    const productTypeSelect = document.getElementById('product-type-{{ section.id }}');
    const concernSelect = document.getElementById('concern-{{ section.id }}');
    const ctaButton = document.getElementById('cta-button-{{ section.id }}');
    const productPreview = document.getElementById('product-preview-{{ section.id }}');
    const productImage = document.getElementById('product-image-{{ section.id }}');
    const productTitle = document.getElementById('product-title-{{ section.id }}');
  
    const mappings = {
      {% for block in section.blocks %}
        {% if block.settings.product_link != blank %}
          "{{ block.settings.product_type | escape }}_{{ block.settings.concern | escape }}": {
            url: "{{ block.settings.product_link.url }}",
            title: "{{ block.settings.product_link.title | escape }}",
            image: "{{ block.settings.product_link.featured_image | image_url: width: 300 }}"
          }
          {% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    };
    
    const concernsByProductType = {};
    {% for block in section.blocks %}
      {%- assign current_type = block.settings.product_type | escape -%}
      {%- assign current_concern = block.settings.concern | escape -%}
      if (!concernsByProductType["{{ current_type }}"]) {
        concernsByProductType["{{ current_type }}"] = [];
      }
      if (concernsByProductType["{{ current_type }}"].indexOf("{{ current_concern }}") === -1) {
        concernsByProductType["{{ current_type }}"].push("{{ current_concern }}");
      }
    {% endfor %}
    
    // Fallback data if no blocks are configured
    if (Object.keys(concernsByProductType).length === 0) {
      concernsByProductType["Serum"] = [
        "Bore i starenje",
        "Hidratacija i suva koža", 
        "Fleke i neujednačen ten",
        "Podočnjaci i natečenost",
        "Akne i upaljena koža",
        "Oštećena koža"
      ];
      concernsByProductType["Krema"] = [
        "Osetljiva i oštećena koža",
        "Podočnjaci i natečenost"
      ];
      concernsByProductType["Maska"] = [
        "Miteseri i proširene pore",
        "Zatezanje i elastičnost"
      ];
      concernsByProductType["Čistač"] = [
        "Čišćenje lica"
      ];
      concernsByProductType["Tonik"] = [
        "Miteseri i proširene pore"
      ];
      concernsByProductType["Ulje za kosu"] = [
        "Opadanje i rast kose"
      ];
      concernsByProductType["Šampon"] = [
        "Opadanje i rast kose"
      ];
      concernsByProductType["Mleko za kosu"] = [
        "Oštećena i suva kosa"
      ];
      concernsByProductType["Tretman za kosu"] = [
        "Volumen i gustina"
      ];
      concernsByProductType["Pasta za zube"] = [
        "Beljenje zuba"
      ];
      concernsByProductType["Prah za zube"] = [
        "Beljenje zuba"
      ];
      concernsByProductType["Set"] = [
        "Bore i starenje",
        "Opadanje i rast kose",
        "Podočnjaci i natečenost"
      ];
    }
    
  
    function updateButtonState() {
      const productType = productTypeSelect.value;
      const concern = concernSelect.value;
      const key = `${productType}_${concern}`;
  
      if (mappings[key]) {
        ctaButton.href = mappings[key].url;
        ctaButton.classList.remove('disabled');
        
        // Show product preview
        productPreview.classList.add('show');
        productImage.src = mappings[key].image;
        productImage.alt = mappings[key].title;
        productImage.style.display = 'block';
        productTitle.textContent = mappings[key].title;
      } else {
        ctaButton.href = '#';
        ctaButton.classList.add('disabled');
        
        // Hide product preview
        productPreview.classList.remove('show');
        productImage.style.display = 'none';
        productTitle.textContent = '';
      }
    }
  
    productTypeSelect.addEventListener('change', function() {
      const selectedType = this.value;
      
      concernSelect.innerHTML = `<option value="" disabled selected>{{ section.settings.concern_placeholder | escape_once }}</option>`;
      
      if (selectedType && concernsByProductType[selectedType]) {
        concernsByProductType[selectedType].forEach(function(concern) {
          const option = document.createElement('option');
          option.value = concern;
          option.textContent = concern;
          concernSelect.appendChild(option);
        });
        concernSelect.disabled = false;
      } else {
        concernSelect.disabled = true;
      }
      
      updateButtonState();
    });
  
    concernSelect.addEventListener('change', updateButtonState);
  });
  </script>
  
  
