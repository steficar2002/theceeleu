{% comment %}
  Responsive Banner Section - Wall-to-wall landscape image with different images for desktop and mobile
  File: sections/responsive-banner.liquid
{% endcomment %}

<style>
    #shopify-section-{{ section.id }} {
      --overlay-opacity: {{ section.settings.overlay_opacity | default: 0 | divided_by: 100.0 }};
      --overlay-color: {{ section.settings.overlay_color | default: '#000000' }};
      --section-margin-top: {{ section.settings.section_margin_top | default: 0 }}px;
      --section-margin-bottom: {{ section.settings.section_margin_bottom | default: 0 }}px;
      --desktop-margin-left: {{ section.settings.desktop_margin_left | default: 0 }}px;
      --desktop-margin-right: {{ section.settings.desktop_margin_right | default: 0 }}px;
    }
  
    #shopify-section-{{ section.id }} .responsive-banner {
      position: relative;
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-top: var(--section-margin-top);
      margin-bottom: var(--section-margin-bottom);
      overflow: hidden;
    }
  
    /* Height settings */
    #shopify-section-{{ section.id }} .responsive-banner.height-small {
      height: 300px;
    }
  
    #shopify-section-{{ section.id }} .responsive-banner.height-medium {
      height: 400px;
    }
  
    #shopify-section-{{ section.id }} .responsive-banner.height-large {
      height: 500px;
    }
  
    #shopify-section-{{ section.id }} .responsive-banner.height-extra-large {
      height: 600px;
    }
  
    #shopify-section-{{ section.id }} .responsive-banner.height-full {
      height: 100vh;
      min-height: 400px;
    }
  
    /* Desktop height adjustments */
    @media (min-width: 769px) {
      #shopify-section-{{ section.id }} .responsive-banner.height-small {
        height: 400px;
      }
  
      #shopify-section-{{ section.id }} .responsive-banner.height-medium {
        height: 500px;
      }
  
      #shopify-section-{{ section.id }} .responsive-banner.height-large {
        height: 600px;
      }
  
      #shopify-section-{{ section.id }} .responsive-banner.height-extra-large {
        height: 700px;
      }
  
      #shopify-section-{{ section.id }} .responsive-banner.height-full {
        height: 100vh;
        min-height: 500px;
      }
    }
  
    /* Desktop margin/padding controls */
    @media (min-width: 769px) {
      #shopify-section-{{ section.id }} .responsive-banner {
        margin-left: calc(-50vw + 50% + var(--desktop-margin-left));
        margin-right: calc(-50vw + 50% + var(--desktop-margin-right));
        width: calc(100vw - var(--desktop-margin-left) - var(--desktop-margin-right));
      }
    }

    /* Auto height based on image aspect ratio */
    {% if section.settings.height == 'auto' and section.settings.desktop_image != blank %}
      @media (min-width: 769px) {
        #shopify-section-{{ section.id }} .responsive-banner.height-auto {
          height: auto;
          aspect-ratio: {{ section.settings.desktop_image.aspect_ratio }};
        }
      }
    {% endif %}
  
    {% if section.settings.height == 'auto' and section.settings.mobile_image != blank %}
      @media (max-width: 768px) {
        #shopify-section-{{ section.id }} .responsive-banner.height-auto {
          height: auto;
          aspect-ratio: {{ section.settings.mobile_image.aspect_ratio }};
        }
      }
    {% endif %}
  
    #shopify-section-{{ section.id }} .banner-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: {{ section.settings.focal_point | default: 'center center' }};
    }
  
    /* Desktop image - hidden on mobile */
    #shopify-section-{{ section.id }} .banner-image-desktop {
      display: block;
    }
  
    /* Mobile image - hidden on desktop */
    #shopify-section-{{ section.id }} .banner-image-mobile {
      display: none;
    }
  
    /* Show mobile image and hide desktop image on mobile */
    @media (max-width: 768px) {
      #shopify-section-{{ section.id }} .banner-image-desktop {
        display: none;
      }
  
      #shopify-section-{{ section.id }} .banner-image-mobile {
        display: block;
      }
    }
  
    /* Overlay */
    #shopify-section-{{ section.id }} .banner-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: var(--overlay-color);
      opacity: var(--overlay-opacity);
      z-index: 1;
    }
  
  </style>
  
  <div class="responsive-banner height-{{ section.settings.height | default: 'medium' }}">
    <!-- Desktop Image -->
    {% if section.settings.desktop_image != blank %}
      <img
        class="banner-image banner-image-desktop"
        src="{{ section.settings.desktop_image | image_url: width: 1920 }}"
        srcset="{{ section.settings.desktop_image | image_url: width: 1920 }} 1920w,
                {{ section.settings.desktop_image | image_url: width: 1440 }} 1440w,
                {{ section.settings.desktop_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.desktop_image | image_url: width: 992 }} 992w"
        sizes="100vw"
        alt="{{ section.settings.desktop_image.alt | default: section.settings.heading }}"
        loading="{% if section.index == 1 %}eager{% else %}lazy{% endif %}"
        {% if section.index == 1 %}fetchpriority="high"{% endif %}
      >
    {% endif %}
  
    <!-- Mobile Image -->
    {% if section.settings.mobile_image != blank %}
      <img
        class="banner-image banner-image-mobile"
        src="{{ section.settings.mobile_image | image_url: width: 768 }}"
        srcset="{{ section.settings.mobile_image | image_url: width: 768 }} 768w,
                {{ section.settings.mobile_image | image_url: width: 576 }} 576w,
                {{ section.settings.mobile_image | image_url: width: 480 }} 480w,
                {{ section.settings.mobile_image | image_url: width: 375 }} 375w"
        sizes="100vw"
        alt="{{ section.settings.mobile_image.alt | default: section.settings.heading }}"
        loading="{% if section.index == 1 %}eager{% else %}lazy{% endif %}"
      >
    {% elsif section.settings.desktop_image != blank %}
      <!-- Fallback to desktop image if mobile image is not set -->
      <img
        class="banner-image banner-image-mobile"
        src="{{ section.settings.desktop_image | image_url: width: 768 }}"
        srcset="{{ section.settings.desktop_image | image_url: width: 768 }} 768w,
                {{ section.settings.desktop_image | image_url: width: 576 }} 576w,
                {{ section.settings.desktop_image | image_url: width: 480 }} 480w,
                {{ section.settings.desktop_image | image_url: width: 375 }} 375w"
        sizes="100vw"
        alt="{{ section.settings.desktop_image.alt | default: section.settings.heading }}"
        loading="{% if section.index == 1 %}eager{% else %}lazy{% endif %}"
      >
    {% endif %}
  
    <!-- Overlay -->
    {% if section.settings.overlay_opacity > 0 %}
      <div class="banner-overlay"></div>
    {% endif %}
  
  </div>
  
  {% schema %}
  {
    "name": "Responsive Banner",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "header",
        "content": "Images"
      },
      {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image",
        "info": "Recommended: 1920x600px or larger landscape image"
      },
      {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image",
        "info": "Recommended: 768x768px or portrait/square image. If not set, desktop image will be used."
      },
      {
        "type": "select",
        "id": "focal_point",
        "label": "Image Focal Point",
        "options": [
          {
            "value": "center center",
            "label": "Center"
          },
          {
            "value": "center top",
            "label": "Top Center"
          },
          {
            "value": "center bottom",
            "label": "Bottom Center"
          },
          {
            "value": "left center",
            "label": "Left Center"
          },
          {
            "value": "right center",
            "label": "Right Center"
          },
          {
            "value": "left top",
            "label": "Top Left"
          },
          {
            "value": "right top",
            "label": "Top Right"
          },
          {
            "value": "left bottom",
            "label": "Bottom Left"
          },
          {
            "value": "right bottom",
            "label": "Bottom Right"
          }
        ],
        "default": "center center"
      },
      {
        "type": "header",
        "content": "Banner Settings"
      },
      {
        "type": "select",
        "id": "height",
        "label": "Banner Height",
        "options": [
          {
            "value": "auto",
            "label": "Auto (Image Aspect Ratio)"
          },
          {
            "value": "small",
            "label": "Small"
          },
          {
            "value": "medium",
            "label": "Medium"
          },
          {
            "value": "large",
            "label": "Large"
          },
          {
            "value": "extra-large",
            "label": "Extra Large"
          },
          {
            "value": "full",
            "label": "Full Screen"
          }
        ],
        "default": "medium"
      },
      {
        "type": "range",
        "id": "section_margin_top",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Section Top Margin",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_margin_bottom",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Section Bottom Margin",
        "default": 0
      },
      {
        "type": "header",
        "content": "Desktop Margins"
      },
      {
        "type": "range",
        "id": "desktop_margin_left",
        "min": 0,
        "max": 400,
        "step": 10,
        "unit": "px",
        "label": "Desktop Left Margin",
        "info": "Adds space on the left side of the banner on desktop only",
        "default": 0
      },
      {
        "type": "range",
        "id": "desktop_margin_right",
        "min": 0,
        "max": 400,
        "step": 10,
        "unit": "px",
        "label": "Desktop Right Margin",
        "info": "Adds space on the right side of the banner on desktop only",
        "default": 0
      },
      {
        "type": "header",
        "content": "Overlay"
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "min": 0,
        "max": 80,
        "step": 5,
        "unit": "%",
        "label": "Overlay Opacity",
        "default": 0
      },
      {
        "type": "color",
        "id": "overlay_color",
        "label": "Overlay Color",
        "default": "#000000"
      },
    ],
    "presets": [
      {
        "name": "Responsive Banner"
      }
    ]
  }
  {% endschema %}
  