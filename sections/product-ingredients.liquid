{% comment %}
  Product Ingredients Section - Displays key ingredients with benefits and scientific backing
  File: sections/product-ingredients.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --ingredients-bg-color: {{ section.settings.background_color | default: '#ffffff' }};
    --ingredients-text-color: {{ section.settings.text_color | default: '#000000' }};
    --ingredients-heading-color: {{ section.settings.heading_color | default: '#000000' }};
    --ingredients-subheading-color: {{ section.settings.subheading_color | default: '#666666' }};
    --ingredients-card-bg: {{ section.settings.card_background_color | default: '#f8f9fa' }};
    --ingredients-card-border: {{ section.settings.card_border_color | default: '#e9ecef' }};
    --ingredients-padding: {{ section.settings.section_padding | default: 60 }}px;
  }

  #shopify-section-{{ section.id }} .ingredients-section {
    background-color: var(--ingredients-bg-color);
    padding: var(--ingredients-padding) 0;
  }

  #shopify-section-{{ section.id }} .ingredients-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .ingredients-header {
    text-align: center;
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .ingredients-heading {
    color: var(--ingredients-heading-color);
    font-size: 2.5rem;
    font-weight: 500;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .ingredients-subheading {
    color: var(--ingredients-subheading-color);
    font-size: 1.125rem;
    font-weight: 400;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .ingredients-grid {
    display: flex; /* <-- MODIFIED */
    flex-wrap: wrap; /* <-- ADDED */
    justify-content: center; /* <-- ADDED (This centers the cards) */
    gap: 24px;
    margin-top: 56px;
    align-items: stretch;
  }

  /* REMOVED old media queries for grid-template-columns.
    Flexbox now handles the wrapping automatically.
  */

  #shopify-section-{{ section.id }} .ingredient-card {
    background-color: var(--ingredients-card-bg);
    border: 1px solid var(--ingredients-card-border);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    flex: 0 1 260px; /* <-- ADDED (Sets a base width for cards) */
  }

  #shopify-section-{{ section.id }} .ingredient-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .ingredient-header {
    padding: 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .ingredient-content {
    padding: 0 24px 24px;
    display: none;
    border-top: 1px solid var(--ingredients-card-border);
    margin-top: 12px;
    padding-top: 20px;
  }

  #shopify-section-{{ section.id }} .ingredient-card.expanded .ingredient-content {
    display: block;
  }

  #shopify-section-{{ section.id }} .ingredient-toggle {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--ingredients-card-bg);
    border: 1px solid var(--ingredients-card-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--ingredients-text-color);
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .ingredient-card.expanded .ingredient-toggle {
    transform: rotate(180deg);
  }

  #shopify-section-{{ section.id }} .ingredient-icon {
    width: 140px;
    height: 140px;
    margin: 0 auto 16px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #666666;
    font-weight: bold;
    overflow: hidden;
    position: relative;
  }

  #shopify-section-{{ section.id }} .ingredient-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .ingredient-icon .icon-fallback {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 24px;
    color: white;
    font-weight: bold;
  }

  #shopify-section-{{ section.id }} .ingredient-name {
    color: var(--ingredients-text-color);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 8px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .ingredient-description {
    color: var(--ingredients-text-color);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 20px;
    opacity: 0.85;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .ingredient-benefits {
    color: var(--ingredients-text-color);
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.9;
    text-align: left;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .ingredient-benefits ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .ingredient-benefits li {
    position: relative;
    padding-left: 24px;
    margin-bottom: 10px;
    font-size: 0.9rem;
  }

  #shopify-section-{{ section.id }} .ingredient-benefits li:before {
    content: "•";
    color: var(--ingredients-text-color);
    font-weight: 600;
    position: absolute;
    left: 0;
    top: 0;
    font-size: 1.1rem;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .ingredients-heading {
      font-size: 2rem;
    }

    #shopify-section-{{ section.id }} .ingredients-subheading {
      font-size: 1rem;
    }

    #shopify-section-{{ section.id }} .ingredients-grid {
      /* grid-template-columns: 1fr; <-- REMOVED */
      gap: 20px;
      margin-top: 40px;
    }

    #shopify-section-{{ section.id }} .ingredient-card {
      padding: 24px 20px;
      flex-basis: 100%; /* <-- ADDED (Ensures 1-column layout on mobile) */
    }

    #shopify-section-{{ section.id }} .ingredient-header {
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .ingredient-icon {
      width: 120px;
      height: 120px;
      margin-bottom: 12px;
    }

    #shopify-section-{{ section.id }} .ingredient-name {
      font-size: 1.375rem;
    }

    #shopify-section-{{ section.id }} .ingredients-container {
      padding: 0 16px;
    }
  }

  /* Hide section if no ingredients are available */
  #shopify-section-{{ section.id }}.ingredients-hidden {
    display: none;
  }
</style>

{% comment %} Check if we have any ingredients to display {% endcomment %}
{% assign has_ingredients = false %}
{% for i in (1..4) %}
  {% assign ingredient_name_key = 'ingredient_' | append: i | append: '_name' %}
  {% assign ingredient_description_key = 'ingredient_' | append: i | append: '_description' %}
  {% assign ingredient_benefits_key = 'ingredient_' | append: i | append: '_benefits' %}
  {% assign ingredient_image_key = 'ingredient_' | append: i | append: '_image' %}
  
  {% if product.metafields.custom[ingredient_name_key] != blank %}
    {% assign has_ingredients = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% if has_ingredients %}
  <div class="ingredients-section">
    <div class="ingredients-container">
      {% if section.settings.heading != blank %}
        <div class="ingredients-header">
          <h2 class="ingredients-heading">{{ section.settings.heading }}</h2>
          {% if section.settings.subheading != blank %}
            <p class="ingredients-subheading">{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="ingredients-grid">
        {% for i in (1..4) %}
          {% assign ingredient_name_key = 'ingredient_' | append: i | append: '_name' %}
          {% assign ingredient_description_key = 'ingredient_' | append: i | append: '_description' %}
          {% assign ingredient_benefits_key = 'ingredient_' | append: i | append: '_benefits' %}
          {% assign ingredient_image_key = 'ingredient_' | append: i | append: '_image' %}
          
          {% assign ingredient_name = product.metafields.custom[ingredient_name_key] %}
          {% assign ingredient_description = product.metafields.custom[ingredient_description_key] %}
          {% assign ingredient_benefits = product.metafields.custom[ingredient_benefits_key] %}
          {% assign ingredient_image = product.metafields.custom[ingredient_image_key] %}
          
          {% if ingredient_name != blank %}
            <div class="ingredient-card" onclick="toggleIngredient(this)">
              <div class="ingredient-toggle">+</div>
              <div class="ingredient-header">
                <div class="ingredient-icon">
                  {% if ingredient_image != blank %}
                    <img 
                      src="{{ ingredient_image | image_url: width: 280 }}"
                      srcset="{{ ingredient_image | image_url: width: 280 }} 280w,
                              {{ ingredient_image | image_url: width: 560 }} 560w"
                      sizes="140px"
                      alt="{{ ingredient_name }}"
                      width="140"
                      height="140"
                      loading="lazy"
                    >
                  {% endif %}
                  <div class="icon-fallback" {% if ingredient_image != blank %}style="display: none;"{% endif %}>
                    {{ ingredient_name | slice: 0, 1 | upcase }}
                  </div>
                </div>
                <h3 class="ingredient-name">{{ ingredient_name }}</h3>
              </div>
              <div class="ingredient-content">
                {% if ingredient_description != blank %}
                  <p class="ingredient-description">{{ ingredient_description }}</p>
                {% endif %}
                {% if ingredient_benefits != blank %}
                  <div class="ingredient-benefits">
                    {% assign benefits_lines = ingredient_benefits | split: '
' %}
                    <ul>
                      {% for line in benefits_lines %}
                        {% if line != blank %}
                          <li>{{ line | strip }}</li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
{% else %}
  {% comment %} Hide section if no ingredients are available {% endcomment %}
  <style>
    #shopify-section-{{ section.id }} {
      display: none;
    }
  </style>
{% endif %}

<script>
function toggleIngredient(card) {
  const isExpanded = card.classList.contains('expanded');
  
  // Close all other ingredient cards
  document.querySelectorAll('#shopify-section-{{ section.id }} .ingredient-card').forEach(function(otherCard) {
    if (otherCard !== card) {
      otherCard.classList.remove('expanded');
      otherCard.querySelector('.ingredient-toggle').textContent = '+';
    }
  });
  
  // Toggle current card
  if (isExpanded) {
    card.classList.remove('expanded');
    card.querySelector('.ingredient-toggle').textContent = '+';
  } else {
    card.classList.add('expanded');
    card.querySelector('.ingredient-toggle').textContent = '−';
  }
}
</script>

{% schema %}
{
  "name": "Product Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Star ingredients & how they work",
      "info": "Main heading for the ingredients section"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Customers often want to know why a product works and which ingredients deliver results. A concise explanation of key ingredients, their functions and science-backed benefits.",
      "info": "Optional subheading text"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background Color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#e9ecef"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Section Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Product Ingredients"
    }
  ]
}
{% endschema %}